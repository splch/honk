diff --git a/src/runtime/honk_noos_riscv64.go b/src/runtime/honk_noos_riscv64.go
new file mode 100644
index 0000000..5d34bda
--- /dev/null
+++ b/src/runtime/honk_noos_riscv64.go
@@ -0,0 +1,39 @@
+// HONK OS: S-mode bring-up helpers for the noos/riscv64 port.
+
+//go:build noos && riscv64
+
+package runtime
+
+import _ "unsafe" // for the go:linkname of honkDTBPtr below
+
+// honkSmode proves the Go runtime executes in S-mode under OpenSBI: it prints a
+// line via the SBI legacy console_putchar call. It needs no heap or goroutines,
+// only a valid stack and g, so it can be called directly from the entry asm.
+//
+//go:nosplit
+func honkSmode() {
+	const s = "honk from Go running in S-mode!\n"
+	for i := 0; i < len(s); i++ {
+		sbiPutchar(s[i])
+	}
+}
+
+// sbiPutchar writes one byte to the console via the SBI legacy console_putchar
+// call (implemented in honk_noos_riscv64.s).
+//
+//go:nosplit
+func sbiPutchar(c byte)
+
+// setSSIP raises a supervisor software interrupt to this hart (sip.SSIP=1),
+// used by the scheduler as its wakeup mechanism in place of the M-mode CLINT.
+//
+//go:nosplit
+func setSSIP()
+
+// honkDTBPtr is the device tree blob address the firmware passed in a1 at boot.
+// The entry stub (rt0_noos_riscv64.s) saves a1 across BSS-clear and stores it
+// here; package arch/riscv64 aliases it via //go:linkname to discover hardware.
+// It is a uintptr, not a pointer, so the garbage collector never scans it.
+//
+//go:linkname honkDTBPtr
+var honkDTBPtr uintptr
diff --git a/src/runtime/honk_noos_riscv64.s b/src/runtime/honk_noos_riscv64.s
new file mode 100644
index 0000000..60aa48c
--- /dev/null
+++ b/src/runtime/honk_noos_riscv64.s
@@ -0,0 +1,21 @@
+// HONK OS: SBI console + S-mode helpers for the noos/riscv64 port.
+
+//go:build noos && riscv64
+
+#include "textflag.h"
+#include "asm_noos_riscv64.h"
+
+// func sbiPutchar(c byte)
+// SBI legacy console_putchar: EID(a7=X17)=0x01, char in a0=X10; ecall traps to
+// OpenSBI (M-mode) which writes the byte to the platform console.
+TEXT ·sbiPutchar(SB),NOSPLIT|NOFRAME,$0-1
+	MOVBU	c+0(FP), X10	// a0 = c
+	MOV	$1, X17		// a7 = SBI EID console_putchar
+	ECALL
+	RET
+
+// func setSSIP()
+// Raise a supervisor software interrupt to self by setting sip.SSIP (bit 1).
+TEXT ·setSSIP(SB),NOSPLIT|NOFRAME,$0-0
+	CSRSI	((1<<1), sip)	// sip.SSIP = 1
+	RET
diff --git a/src/runtime/rt0_noos_riscv64.s b/src/runtime/rt0_noos_riscv64.s
index 2335542..8337fc0 100644
--- a/src/runtime/rt0_noos_riscv64.s
+++ b/src/runtime/rt0_noos_riscv64.s
@@ -29,6 +29,54 @@ GLOBL runtime·waitInit(SB), NOPTR, $4
 
 // _rt0_riscv64_noos initializes all running cores
 TEXT _rt0_riscv64_noos(SB),NOSPLIT|NOFRAME,$0
+	// ---- HONK OS S-mode bring-up (single hart, increment 1) ----
+	// OpenSBI handed off in S-mode; X10(a0)=hartid, X11(a1)=DTB. Set up a
+	// stack, enable the FPU state, zero BSS, point g at harts[0], then call the
+	// Go function honkSmode to prove the Go runtime executes in S-mode (it
+	// prints via an SBI ecall). The original M-mode bootstrap below is left
+	// intact for linking but is not reached yet.
+	MOV    X11, S2               // HONK: hold a1 (DTB ptr) in S2 across the BSS clear
+	                             // (memclr scratches S1/X9, so S1 would not survive)
+	CSRCI  ((1<<SIEn), sstatus)  // clear sstatus.SIE (interrupts off)
+	MOV    $(1<<FSn), S0
+	CSRS   (s0, sstatus)         // sstatus.FS = Initial (enable FP state)
+
+	// SP = just above runtime end + one handler stack, 16-byte aligned
+	MOV  $runtime·end(SB), A0
+	ADD  $(handlerStackSize+15), A0
+	AND  $~15, A0
+	MOV  A0, X2
+
+	// zero BSS..ramend. Safe to clear the stack region: the return address is
+	// in RA (RISC-V link register), and memclr is a leaf that never spills it.
+	MOV   $runtime·bss(SB), A0
+	MOV   $runtime·ramend(SB), A1
+	SUB   A0, A1
+	CALL  ·memclrNoHeapPointers<ABIInternal>(SB)
+
+	// publish the saved DTB pointer now that BSS (which holds it) is cleared
+	MOV   S2, ·honkDTBPtr(SB)
+
+	// g = &harts[0]; set stack bounds and gh/mh links (mirrors the M-mode path)
+	MOV  $runtime·harts(SB), g
+	ADD  $-handlerStackSize, X2, A0
+	MOV  A0, (g_stack+stack_lo)(g)
+	MOV  X2, (g_stack+stack_hi)(g)
+	ADD  $cpuctx_mh, g, A0
+	MOV  g, m_g0(A0)
+	MOV  g, m_gsignal(A0)
+	MOV  A0, g_m(g)
+
+	// Enable the individual S-mode interrupts (still globally masked by SIE=0
+	// until rt0_go's SRET raises SPIE->SIE), install the trap vector, clear
+	// sscratch, then enter the real runtime bootstrap.
+	MOV   $intEnabled, S0
+	CSRW  (s0, sie)
+	MOV   $·trapHandler(SB), A0
+	CSRW  (a0, stvec)
+	CSRWI (0, sscratch)
+	JMP   runtime·rt0_go(SB)
+
 	// Disable interrupts globally, enable FPU (Kendryte K210 supports only
 	// FS=0(off)/3(dirty), this is a weakness of the Rocket Chip Generator used
 	// to generate K210 cores).
@@ -226,9 +269,16 @@ TEXT runtime·rt0_go(SB),NOSPLIT|NOFRAME,$0
 	MOV   A0, g_m(A1)  // harts[0].gh.m = harts[0].mh
 	CSRW  (a1, mscratch)
 
-	// switch to the user mode
+	// HONK S/U split (xv6 model): goroutines run in U-mode so their ecall
+	// syscalls trap *down* to our S-mode handler (an ecall from S would go up to
+	// OpenSBI instead). Clear sstatus.SPP=0 (return to U) and set SPIE=1 so
+	// interrupts are enabled after the SRET lands on the next instruction.
+	MOV    $(1<<SPPn), S0
+	CSRC   (s0, mstatus)   // sstatus.SPP = 0 -> SRET returns to U-mode
+	MOV    $(1<<SPIEn), S0
+	CSRS   (s0, mstatus)   // sstatus.SPIE = 1
 	AUIPC  $0, A0
-	ADD    $16, A0  // A0 must point just after MRET
+	ADD    $16, A0  // A0 must point just after the SRET below
 	CSRW   (a0, mepc)
 	MRET
 
